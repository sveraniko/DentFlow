APP_NAME=DentFlow
APP_ENV=dev
APP_DEFAULT_LOCALE=ru
APP_DEFAULT_TIMEZONE=UTC
APP_RUN_MODE=bootstrap

TELEGRAM_PATIENT_BOT_TOKEN=replace_me
TELEGRAM_CLINIC_ADMIN_BOT_TOKEN=replace_me
TELEGRAM_DOCTOR_BOT_TOKEN=replace_me
TELEGRAM_OWNER_BOT_TOKEN=replace_me

DB_DSN=postgresql+asyncpg://dentflow:dentflow@localhost:5432/dentflow
DB_ECHO=false

REDIS_URL=redis://localhost:6379/0

SEARCH_ENABLED=false
SEARCH_MEILI_ENDPOINT=http://localhost:7700
SEARCH_MEILI_API_KEY=
SEARCH_MEILI_INDEX_PREFIX=dentflow
SEARCH_MEILI_TIMEOUT_SEC=2
SEARCH_MEILI_BATCH_SIZE=500

STORAGE_BUCKET=dentflow-local
STORAGE_ENDPOINT=http://localhost:9000

AI_PROVIDER=disabled
AI_ENABLED=false

INTEGRATIONS_GOOGLE_SHEETS_ENABLED=false
INTEGRATIONS_GOOGLE_CALENDAR_ENABLED=false
INTEGRATIONS_GOOGLE_CALENDAR_CREDENTIALS_PATH=
INTEGRATIONS_GOOGLE_CALENDAR_SUBJECT_EMAIL=
INTEGRATIONS_GOOGLE_CALENDAR_APPLICATION_NAME=DentFlow
INTEGRATIONS_GOOGLE_CALENDAR_TIMEOUT_SEC=10
INTEGRATIONS_DENTFLOW_BASE_URL=https://dentflow.local

LOGGING_LEVEL=INFO
LOGGING_JSON=false

STT_ENABLED=false
STT_PROVIDER=fake
STT_TIMEOUT_SEC=5
STT_LANGUAGE_HINT=auto
STT_CONFIDENCE_THRESHOLD=0.7
STT_MAX_VOICE_DURATION_SEC=30
STT_MAX_VOICE_FILE_SIZE_BYTES=2000000
STT_MODE_TTL_SEC=45

STT_OPENAI_API_KEY=
STT_OPENAI_MODEL=gpt-4o-mini-transcribe
STT_OPENAI_ENDPOINT=https://api.openai.com/v1/audio/transcriptions

WORKER_MODE=projector
PROJECTOR_WORKER_ENABLED=true
PROJECTOR_WORKER_BATCH_LIMIT=200
PROJECTOR_WORKER_POLL_INTERVAL_SEC=1.0
PROJECTOR_WORKER_STARTUP_CATCHUP_MAX_BATCHES=20
REMINDER_WORKER_DELIVERY_BATCH_LIMIT=50
REMINDER_WORKER_RECOVERY_BATCH_LIMIT=100
REMINDER_WORKER_POLL_INTERVAL_SEC=2.0
REMINDER_WORKER_STARTUP_CATCHUP_MAX_BATCHES=10
REMINDER_WORKER_LEASE_TTL_SEC=30
REMINDER_WORKER_MAX_CONSECUTIVE_ERROR_BATCHES=3
REMINDER_WORKER_ERROR_COOLDOWN_SEC=10.0
REMINDER_WORKER_INSTANCE_ID=
REMINDER_DELIVERY_BATCH_LIMIT=50
